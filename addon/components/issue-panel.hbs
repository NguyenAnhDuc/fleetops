<Overlay
    @onLoad={{this.setOverlayContext}}
    @onOpen={{this.onOpen}}
    @onClose={{this.onClose}}
    @onToggle={{this.onToggle}}
    @position="right"
    @noBackdrop={{true}}
    @fullHeight={{true}}
    @isResizable={{or this.isResizable @isResizable}}
    @width={{or this.width @width "570px"}}
>
    <Overlay::Header @title={{t "fleet-ops.component.issue-form-panel.car-repair-supplies"}} 
        {{!-- @status={{this.issue.public_id}}  --}}
        @hideStatusDot={{true}} @createdAt={{this.issue.createdAt}}>
        <Button @type="default" @icon="pen" @helpText={{t "fleet-ops.component.issue-panel.edit-issue"}} @onClick={{this.onEdit}} @wrapperClass="mr-2" @permission="fleet-ops update issue" />
        <Button
            @type="default"
            @icon="times"
            @helpText={{if this.issue.id (t "fleet-ops.component.issue-panel.cancel-edit-issue") (t "fleet-ops.component.issue-panel.cancel-new-issue")}}
            @onClick={{this.onPressCancel}}
        />
    </Overlay::Header>
    <Overlay::Body @wrapperClass="overflow-y-auto">
        <IssuePanel::Details @issue={{this.issue}} />
        <Spacer @height="300px" />
    </Overlay::Body>
</Overlay>