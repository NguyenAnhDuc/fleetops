<Modal::Default @modalIsOpened={{@modalIsOpened}} @options={{@options}} @confirm={{@onConfirm}} @decline={{@onDecline}}>
    <div class="modal-body-container space-y-4">

        <ContentPanel @title={{t "fleet-ops.operations.orders.index.view.view-fees-driver-title"}} @open={{true}} @pad={{true}} @panelBodyClass="bg-white dark:bg-gray-800">

            {{!-- Header 2 cột --}}
            <div class="grid grid-cols-2 gap-2 mb-3 px-1">
                <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide">
                    {{t "fleet-ops.operations.orders.index.view.fees-driver-col"}}
                </div>
                <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide">
                    {{t "fleet-ops.operations.orders.index.view.fees-approved-col"}}
                </div>
            </div>

            {{!-- Cầu đường --}}
            <div class="grid grid-cols-2 gap-2 items-center py-2 border-b border-gray-700">
                <div>
                    <div class="text-xs text-gray-400">{{t "fleet-ops.operations.orders.index.view.roadLaw-fees"}}</div>
                    <div class="text-sm font-medium text-white">{{get this.driverFeesFormatted "roadLaw_fee"}}</div>
                </div>
                <div class="flex items-center gap-1">
                    <input
                        type="text" inputmode="numeric"
                        class="form-input w-full text-xs"
                        value={{this.approvedFees.roadLaw_fee}}
                        {{on "change" (fn this.updateFee "roadLaw_fee")}}
                    />
                    {{#if this.editedRoadLawFee}}
                        <span style="color:#22c55e;font-size:16px;font-weight:bold;line-height:1;flex-shrink:0;">✓</span>
                    {{/if}}
                </div>
            </div>

            {{!-- Ăn uống --}}
            <div class="grid grid-cols-2 gap-2 items-center py-2 border-b border-gray-700">
                <div>
                    <div class="text-xs text-gray-400">{{t "fleet-ops.operations.orders.index.view.food-fees"}}</div>
                    <div class="text-sm font-medium text-white">{{get this.driverFeesFormatted "food_fee"}}</div>
                </div>
                <div class="flex items-center gap-1">
                    <input
                        type="text" inputmode="numeric"
                        class="form-input w-full text-xs"
                        value={{this.approvedFees.food_fee}}
                        {{on "change" (fn this.updateFee "food_fee")}}
                    />
                    {{#if this.editedFoodFee}}
                        <span style="color:#22c55e;font-size:16px;font-weight:bold;line-height:1;flex-shrink:0;">✓</span>
                    {{/if}}
                </div>
            </div>

            {{!-- Bốc vác --}}
            <div class="grid grid-cols-2 gap-2 items-center py-2 border-b border-gray-700">
                <div>
                    <div class="text-xs text-gray-400">{{t "fleet-ops.operations.orders.index.view.handling-fees"}}</div>
                    <div class="text-sm font-medium text-white">{{get this.driverFeesFormatted "handling_fee"}}</div>
                </div>
                <div class="flex items-center gap-1">
                    <input
                        type="text" inputmode="numeric"
                        class="form-input w-full text-xs"
                        value={{this.approvedFees.handling_fee}}
                        {{on "change" (fn this.updateFee "handling_fee")}}
                    />
                    {{#if this.editedHandlingFee}}
                        <span style="color:#22c55e;font-size:16px;font-weight:bold;line-height:1;flex-shrink:0;">✓</span>
                    {{/if}}
                </div>
            </div>

            {{!-- Sửa xe --}}
            <div class="grid grid-cols-2 gap-2 items-center py-2 border-b border-gray-700">
                <div>
                    <div class="text-xs text-gray-400">{{t "fleet-ops.operations.orders.index.view.repair-fees"}}</div>
                    <div class="text-sm font-medium text-white">{{get this.driverFeesFormatted "repair_fee"}}</div>
                </div>
                <div class="flex items-center gap-1">
                    <input
                        type="text" inputmode="numeric"
                        class="form-input w-full text-xs"
                        value={{this.approvedFees.repair_fee}}
                        {{on "change" (fn this.updateFee "repair_fee")}}
                    />
                    {{#if this.editedRepairFee}}
                        <span style="color:#22c55e;font-size:16px;font-weight:bold;line-height:1;flex-shrink:0;">✓</span>
                    {{/if}}
                </div>
            </div>

            {{!-- Nguyên liệu --}}
            <div class="grid grid-cols-2 gap-2 items-center py-2 border-b border-gray-700">
                <div>
                    <div class="text-xs text-gray-400">{{t "fleet-ops.operations.orders.index.view.external-fuel-fees"}}</div>
                    <div class="text-sm font-medium text-white">{{get this.driverFeesFormatted "external_fuel_fee"}}</div>
                </div>
                <div class="flex items-center gap-1">
                    <input
                        type="text" inputmode="numeric"
                        class="form-input w-full text-xs"
                        value={{this.approvedFees.external_fuel_fee}}
                        {{on "change" (fn this.updateFee "external_fuel_fee")}}
                    />
                    {{#if this.editedExternalFuelFee}}
                        <span style="color:#22c55e;font-size:16px;font-weight:bold;line-height:1;flex-shrink:0;">✓</span>
                    {{/if}}
                </div>
            </div>

            {{!-- Khác --}}
            <div class="grid grid-cols-2 gap-2 items-center py-2">
                <div>
                    <div class="text-xs text-gray-400">{{t "fleet-ops.operations.orders.index.view.other-fees"}}</div>
                    <div class="text-sm font-medium text-white">{{get this.driverFeesFormatted "other_fee"}}</div>
                </div>
                <div class="flex items-center gap-1">
                    <input
                        type="text" inputmode="numeric"
                        class="form-input w-full text-xs"
                        value={{this.approvedFees.other_fee}}
                        {{on "change" (fn this.updateFee "other_fee")}}
                    />
                    {{#if this.editedOtherFee}}
                        <span style="color:#22c55e;font-size:16px;font-weight:bold;line-height:1;flex-shrink:0;">✓</span>
                    {{/if}}
                </div>
            </div>

            {{!-- Tổng --}}
            <div class="grid grid-cols-2 gap-2 items-center mt-3 pt-3 border-t-2 border-gray-600">
                <div>
                    <span class="text-xs font-bold text-gray-300 uppercase tracking-wide">
                        {{t "fleet-ops.operations.orders.index.view.total-fees-driver"}}
                    </span>
                    <span class="text-sm font-bold text-white ml-2">{{get this.driverFeesFormatted "total"}}</span>
                </div>
                <div class="text-sm font-bold text-blue-400">{{this.formattedTotal}}</div>
            </div>

            {{!-- Hóa đơn --}}
            {{#if @options.order.image_billing_urls.length}}
                <div class="mt-3 pt-3 border-t border-gray-700">
                    <div class="text-xs font-semibold text-gray-400 mb-2">Hóa đơn</div>
                    <div class="flex overflow-x-auto space-x-4 py-1">
                        {{#each @options.order.image_billing_urls as |url|}}
                            <a href={{url}} target="_blank" rel="noopener noreferrer">
                                <img src={{url}} alt="Billing" class="w-28 h-28 object-cover rounded-lg border border-gray-600 hover:scale-105 transition-transform" />
                            </a>
                        {{/each}}
                    </div>
                </div>
            {{/if}}
        </ContentPanel>

        {{!-- Ghi chú duyệt --}}
        <ContentPanel
            @title={{t "fleet-ops.operations.orders.index.view.approval-fees-title"}}
            @open={{true}}
            @pad={{true}}
            @panelBodyClass="bg-white dark:bg-gray-800"
        >
            <Textarea
                @value={{@options.order.note_approval_fees}}
                class="form-input w-full text-xs"
                placeholder={{t "fleet-ops.operations.orders.index.new.notes-approval-fees-placeholder"}}
                rows={{3}}
            />
        </ContentPanel>

    </div>
</Modal::Default>
