<Modal::Default @modalIsOpened={{@modalIsOpened}} @options={{@options}} @confirm={{@onConfirm}} @decline={{@onDecline}}>
    <div class="modal-body-container">
        <div class="grid grid-cols-2 flex-col md:flex-row gap-2 mb-6">
            <div class="field-info-container space-y-2">
                <div class="field-name">{{t "fleet-ops.common.driver"}}</div>
                <div class="field-value">{{n-a @options.fuelReport.driver_name}}</div>
            </div>
            <div class="field-info-container space-y-2">
                <div class="field-name">{{t "fleet-ops.common.vehicle"}}</div>
                <div class="field-value">{{n-a @options.fuelReport.vehicle_name}}</div>
            </div>

            <div class="field-info-container space-y-2">
                <div class="field-name">Ngày đổ dầu</div>
                <div class="field-value">{{n-a @options.fuelReport.fueledAtShort}}</div>
            </div>
            <div class="field-info-container space-y-2">
                <div class="field-name">{{t "fleet-ops.common.odometer"}}</div>
                <div class="field-value">
                    {{n-a @options.fuelReport.odometerDisplay}}
                </div>
            </div>

            <div class="field-info-container space-y-2">
                <div class="field-name">Thể tích / Khối lượng</div>
                <div class="field-value">
                    {{n-a @options.fuelReport.volume}}{{#if @options.fuelReport.volume_extra}} (+{{@options.fuelReport.volume_extra}}){{/if}} {{n-a @options.fuelReport.metric_unit}}
                </div>
            </div>
            <div class="field-info-container space-y-2">
                <div class="field-name">Đơn giá</div>
                <div class="field-value">{{n-a @options.fuelReport.unitPriceDisplay}}</div>
            </div>

            <div class="field-info-container space-y-2">
                <div class="field-name">Chi phí (Tổng cộng)</div>
                <div class="field-value">{{n-a @options.fuelReport.amountDisplay}}</div>
            </div>
            <div class="field-info-container space-y-2">
                <div class="field-name">Chi phí phụ / Tăng thêm</div>
                <div class="field-value">{{n-a @options.fuelReport.amountExtraDisplay}}</div>
            </div>

            <div class="field-info-container space-y-2">
                <div class="field-name">{{t "fleet-ops.common.date-created"}}</div>
                <div class="field-value">{{@options.fuelReport.createdAtShort}}</div>
            </div>
            <div class="field-info-container space-y-2">
                <div class="field-name">Trạng thái</div>
                <div class="field-value">
                    <Badge @status={{@options.fuelReport.status}} />
                </div>
            </div>
        </div>
    </div>
</Modal::Default>