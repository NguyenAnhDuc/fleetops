<Overlay
    @onLoad={{this.setOverlayContext}}
    @onOpen={{this.onOpen}}
    @onClose={{this.onClose}}
    @onToggle={{this.onToggle}}
    @position="right"
    @noBackdrop={{true}}
    @fullHeight={{true}}
    @isResizable={{or this.isResizable @isResizable}}
    @width={{or this.width @width "600px"}}
>
    <Overlay::Header
        @title={{if
            this.issue.public_id
            (concat (t "fleet-ops.component.issue-form-panel.car-repair-supplies") " : " (format-date this.issue.created_at "MMM dd, yyyy HH:mm"))
            (t "fleet-ops.component.issue-form-panel.new-car-repair-supplies")
        }}
        @hideStatusDot={{true}}
        @titleWrapperClass="leading-5"
    >
        <div class="flex flex-1 justify-end">
            <Button
                @icon={{if this.issue.id "save" "check"}}
                @type="primary"
                @text={{if this.issue.id (t "fleet-ops.component.issue-form-panel.save-car-repair-supplies") (t "fleet-ops.component.issue-form-panel.create-car-repair-supplies")}}
                @onClick={{perform this.save}}
                @isLoading={{this.save.isRunning}}
                @permission={{this.savePermission}}
                @wrapperClass="mr-2"
            />
            {{#if this.issue.id}}
                <Button
                    @type="default"
                    @icon="circle-exclamation"
                    @helpText={{t "fleet-ops.component.issue-form-panel.detail-car-repair-supplies"}}
                    @onClick={{this.onViewDetails}}
                    @wrapperClass="mr-2"
                    @permission="fleet-ops view issue"
                />
            {{/if}}
            <Button
                @type="default"
                @icon="times"
                @helpText={{t "fleet-ops.component.issue-form-panel.cancel-car-repair-supplies"}}
                @onClick={{this.onPressCancel}}
            />
        </div>
    </Overlay::Header>

    <Overlay::Body @wrapperClass="px-4 pt-4">
        {{#let (cannot this.savePermission) as |unauthorized|}}
            <div class="flex flex-col gap-4 pb-8">

                {{!-- Line 1: Phương tiện + Ngày tạo đơn --}}
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
                            {{t "fleet-ops.common.vehicle"}}
                            <span class="text-red-500 ml-0.5">*</span>
                        </label>
                        <ModelSelect
                            @modelName="vehicle"
                            @selectedModel={{this.issue.vehicle}}
                            @placeholder={{t "fleet-ops.component.issue-form-panel.select-vehicle"}}
                            @triggerClass="form-select form-input w-full"
                            @infiniteScroll={{false}}
                            @renderInPlace={{true}}
                            @onChange={{fn (mut this.issue.vehicle)}}
                            @disabled={{unauthorized}}
                            as |model|
                        >
                            {{model.displayName}}
                        </ModelSelect>
                        {{#if this.validationErrors.vehicle}}
                            <p class="mt-1 text-xs text-red-500">{{this.validationErrors.vehicle}}</p>
                        {{/if}}
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
                            {{t "fleet-ops.common.car_repair_date"}}
                            <span class="text-red-500 ml-0.5">*</span>
                        </label>
                        <input
                            type="date"
                            class="form-input w-full"
                            value={{this.issue.carRepairDate}}
                            disabled={{unauthorized}}
                            {{on "change" (fn this.onDateChange)}}
                        />
                        {{#if this.validationErrors.car_repair_date}}
                            <p class="mt-1 text-xs text-red-500">{{this.validationErrors.car_repair_date}}</p>
                        {{/if}}
                    </div>
                </div>

                {{!-- Line 2+: Hạng mục chi phí (dynamic) --}}
                <div>
                    <div class="flex items-center justify-between mb-2">
                        <div>
                            <span class="text-xs font-medium text-gray-700 dark:text-gray-300">
                                {{t "fleet-ops.component.issue-form-panel.items-label"}}
                                <span class="text-red-500 ml-0.5">*</span>
                            </span>
                            {{#if this.validationErrors.items}}
                                <span class="ml-2 text-xs text-red-500">{{this.validationErrors.items}}</span>
                            {{/if}}
                        </div>
                        <button
                            type="button"
                            class="flex items-center gap-1 px-2 py-1 text-xs font-medium text-white bg-blue-600 hover:bg-blue-700 rounded transition-colors disabled:opacity-50"
                            {{on "click" this.addItem}}
                            disabled={{unauthorized}}
                        >
                            <FaIcon @icon="plus" @size="xs" />
                            {{t "fleet-ops.component.issue-form-panel.add-item"}}
                        </button>
                    </div>

                    {{!-- Header row --}}
                    {{#if this.items.length}}
                        <div class="grid grid-cols-12 gap-2 mb-1 px-1">
                            <span class="col-span-7 text-xs text-gray-500 dark:text-gray-400">{{t "fleet-ops.component.issue-form-panel.item-name-header"}}</span>
                            <span class="col-span-4 text-xs text-gray-500 dark:text-gray-400">{{t "fleet-ops.component.issue-form-panel.item-money-header"}}</span>
                            <span class="col-span-1"></span>
                        </div>
                    {{/if}}

                    {{!-- Items list: max 4 rows, scroll khi > 4 --}}
                    <div class="overflow-y-auto border border-gray-100 dark:border-gray-700 rounded-lg p-2" style="max-height: 184px;">
                        {{#if this.items.length}}
                            <div class="space-y-2 pr-1">
                                {{#each this.items as |item index|}}
                                    <div class="grid grid-cols-12 gap-2 items-start">
                                        <div class="col-span-7">
                                            <input
                                                type="text"
                                                class="form-input w-full text-xs {{if item.nameError "border-red-400"}}"
                                                placeholder={{or item.namePlaceholder (t "fleet-ops.component.issue-form-panel.item-name-placeholder")}}
                                                value={{item.name}}
                                                disabled={{unauthorized}}
                                                {{on "change" (fn this.updateItemField index "name")}}
                                            />
                                            {{#if item.nameError}}
                                                <p class="text-xs text-red-500 mt-0.5">{{item.nameError}}</p>
                                            {{/if}}
                                        </div>
                                        <div class="col-span-4">
                                            <input
                                                type="text"
                                                inputmode="numeric"
                                                class="form-input w-full text-xs {{if item.moneyError "border-red-400"}}"
                                                placeholder="0"
                                                value={{item.money}}
                                                disabled={{unauthorized}}
                                                {{on "change" (fn this.updateItemField index "money")}}
                                            />
                                            {{#if item.moneyError}}
                                                <p class="text-xs text-red-500 mt-0.5">{{item.moneyError}}</p>
                                            {{/if}}
                                        </div>
                                        <div class="col-span-1 flex justify-center pt-1">
                                            <button
                                                type="button"
                                                class="w-6 h-6 flex items-center justify-center text-red-400 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 rounded transition-colors disabled:opacity-50"
                                                {{on "click" (fn this.removeItem index)}}
                                                disabled={{unauthorized}}
                                            >
                                                <FaIcon @icon="trash" @size="xs" />
                                            </button>
                                        </div>
                                    </div>
                                {{/each}}
                            </div>
                        {{else}}
                            <div class="text-xs text-gray-400 dark:text-gray-500 italic py-4 text-center border border-dashed border-gray-300 dark:border-gray-600 rounded-lg">
                                <FaIcon @icon="receipt" class="text-gray-300 dark:text-gray-600 mb-1" @size="lg" />
                                <p>{{t "fleet-ops.component.issue-form-panel.no-items"}}</p>
                            </div>
                        {{/if}}
                    </div>

                    {{!-- Tổng tiền --}}
                    {{#if this.items.length}}
                        <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-200 dark:border-gray-600">
                            <span class="text-xs font-semibold text-gray-700 dark:text-gray-300">
                                {{t "fleet-ops.common.total_money"}}
                            </span>
                            <span class="text-sm font-bold text-blue-600 dark:text-blue-400">
                                {{this.formattedTotalMoney}}
                            </span>
                        </div>
                    {{/if}}
                </div>

                {{!-- Ghi chú --}}
                <div>
                    <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
                        {{t "fleet-ops.component.issue-form-panel.note-car-repair-supplies"}}
                    </label>
                    <Textarea
                        @value={{this.issue.report}}
                        aria-label="Issue Report"
                        class="w-full form-input text-xs"
                        disabled={{unauthorized}}
                        placeholder={{t "fleet-ops.component.issue-form-panel.note-car-repair-supplies"}}
                        rows={{3}}
                    />
                </div>

                {{!-- Hình ảnh --}}
                <div>
                    <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
                        {{t "fleet-ops.common.image"}}
                        <span class="text-xs text-gray-400 ml-1">({{t "fleet-ops.component.issue-form-panel.upload-image-help"}})</span>
                    </label>
                    <div class="flex items-center gap-3">
                        <Image src={{this.issue.photo_url}} alt="Image" height="80" width="80" class="h-20 w-20 rounded-md object-cover border border-gray-200 dark:border-gray-600" />
                        <UploadButton @name={{t "fleet-ops.common.photos"}} @accept="image/*" @onFileAdded={{this.onImageFileAdded}} class="w-32" />
                    </div>
                </div>

                <RegistryYield @registry="fleet-ops:component:issue-form-panel:details" as |RegistryComponent|>
                    <RegistryComponent @issue={{this.issue}} @controller={{this.controller}} @permission={{this.savePermission}} />
                </RegistryYield>

            </div>

            <RegistryYield @registry="fleet-ops:component:issue-form-panel" as |RegistryComponent|>
                <RegistryComponent @issue={{this.issue}} @controller={{this.controller}} @permission={{this.savePermission}} />
            </RegistryYield>
        {{/let}}
    </Overlay::Body>
</Overlay>
