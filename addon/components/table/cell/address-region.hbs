<div class="flex items-start gap-1">
    {{#if this.style}}
        <span class="inline-block px-1 rounded text-xs font-bold flex-shrink-0 mt-0.5" style={{this.badgeStyle}}>
            {{this.style.label}}
        </span>
    {{/if}}
    <span class="text-xs truncate" style={{this.textStyle}}>
        {{this.address}}
    </span>
</div>
